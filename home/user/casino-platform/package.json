{
  "name": "casino-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @casino/api dev",
    "dev:web": "pnpm --filter @casino/web dev",
    "dev:admin": "pnpm --filter @casino/admin dev",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @casino/database generate",
    "db:migrate": "pnpm --filter @casino/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @casino/database migrate:deploy",
    "db:seed": "pnpm --filter @casino/database seed",
    "db:studio": "pnpm --filter @casino/database studio",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@casino/eslint-config": "workspace:*",
    "@casino/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
